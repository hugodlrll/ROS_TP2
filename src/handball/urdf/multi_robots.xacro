<?xml version="1.0"?>
<robot name="multi_robots" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Root link -->
  <link name="world"/>

  <!-- Macro definition -->
  <xacro:macro name="robot_body" params="name color">

    <xacro:property name="rgba"
                    value="${'0 0 1 1' if color == 'blue' else '1 0 0 1'}"/>

    <!-- Base link -->
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0.05"/>
        <geometry>
          <box size="0.4 0.6 0.1"/>
        </geometry>
        <material name="${name}_mat">
          <color rgba="${rgba}"/>
        </material>
      </visual>
    </link>

    <!-- Front extension -->
    <link name="${name}_front">
      <visual>
        <origin xyz="0.18 0 0.05" rpy="0 0 0.785398"/>
        <geometry>
          <box size="0.3 0.3 0.1"/>
        </geometry>
        <material name="${name}_mat"/>
      </visual>
    </link>

    <joint name="${name}_front_joint" type="fixed">
      <parent link="${name}"/>
      <child link="${name}_front"/>
    </joint>

    <!-- Attach robot to world -->
    <joint name="${name}_world_joint" type="fixed">
      <parent link="world"/>
      <child link="${name}"/>
    </joint>

  </xacro:macro>

  <!-- Instantiate robots -->
  <xacro:robot_body name="blue_0" color="blue"/>
  <xacro:robot_body name="blue_1" color="blue"/>
  <xacro:robot_body name="blue_2" color="blue"/>

  <xacro:robot_body name="red_0" color="red"/>
  <xacro:robot_body name="red_1" color="red"/>
  <xacro:robot_body name="red_2" color="red"/>
  
  <!-- ===================== TERRAIN ===================== -->
  <link name="field_floor">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="40.0 20.0 0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0.2 0.6 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="field_floor_joint" type="fixed">
    <parent link="world"/>
    <child link="field_floor"/>
    <origin xyz="0 0 -0.025" rpy="0 0 0"/>
  </joint>
  
  <!-- ===================== LIGNE CENTRALE ===================== -->
  <link name="center_line">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 20.0 0.01"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="center_line_joint" type="fixed">
    <parent link="world"/>
    <child link="center_line"/>
    <origin xyz="0 0 0.001" rpy="0 0 0"/>
  </joint>

  <!-- ===================== BUT BLEU (gauche, x = -20) ===================== -->
  <link name="blue_goal_post_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="2.0"/>
      </geometry>
      <material name="blue_goal">
        <color rgba="0.1 0.1 0.9 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="blue_goal_post_left_joint" type="fixed">
    <parent link="world"/>
    <child link="blue_goal_post_left"/>
    <origin xyz="-20.0 -1.5 1.0" rpy="0 0 0"/>
  </joint>

  <link name="blue_goal_post_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="2.0"/>
      </geometry>
      <material name="blue_goal"/>
    </visual>
  </link>
  <joint name="blue_goal_post_right_joint" type="fixed">
    <parent link="world"/>
    <child link="blue_goal_post_right"/>
    <origin xyz="-20.0 1.5 1.0" rpy="0 0 0"/>
  </joint>

  <link name="blue_goal_crossbar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 3.0 0.05"/>
      </geometry>
      <material name="blue_goal"/>
    </visual>
  </link>
  <joint name="blue_goal_crossbar_joint" type="fixed">
    <parent link="world"/>
    <child link="blue_goal_crossbar"/>
    <origin xyz="-20.0 0.0 2.0" rpy="0 0 0"/>
  </joint>

  <!-- ===================== BUT ROUGE (droite, x = +20) ===================== -->
  <link name="red_goal_post_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="2.0"/>
      </geometry>
      <material name="red_goal">
        <color rgba="0.9 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="red_goal_post_left_joint" type="fixed">
    <parent link="world"/>
    <child link="red_goal_post_left"/>
    <origin xyz="20.0 -1.5 1.0" rpy="0 0 0"/>
  </joint>

  <link name="red_goal_post_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="2.0"/>
      </geometry>
      <material name="red_goal"/>
    </visual>
  </link>
  <joint name="red_goal_post_right_joint" type="fixed">
    <parent link="world"/>
    <child link="red_goal_post_right"/>
    <origin xyz="20.0 1.5 1.0" rpy="0 0 0"/>
  </joint>

  <link name="red_goal_crossbar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 3.0 0.05"/>
      </geometry>
      <material name="red_goal"/>
    </visual>
  </link>
  <joint name="red_goal_crossbar_joint" type="fixed">
    <parent link="world"/>
    <child link="red_goal_crossbar"/>
    <origin xyz="20.0 0.0 2.0" rpy="0 0 0"/>
  </joint>
  
  <!-- ===================== ZONE DE BUT BLEUE (x=-20) ===================== -->
  <!-- Ligne droite devant le but : de y=-1.5 à y=1.5 à x=-14 -->
  <link name="blue_zone_front">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 14.0 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="blue_zone_front_joint" type="fixed">
    <parent link="world"/>
    <child link="blue_zone_front"/>
    <origin xyz="-14.0 0.0 0.001" rpy="0 0 0"/>
  </joint>

  <!-- Ligne latérale gauche zone bleue -->
  <link name="blue_zone_side_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="6.0 0.05 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="blue_zone_side_left_joint" type="fixed">
    <parent link="world"/>
    <child link="blue_zone_side_left"/>
    <origin xyz="-17.0 -7.0 0.001" rpy="0 0 0"/>
  </joint>

  <!-- Ligne latérale droite zone bleue -->
  <link name="blue_zone_side_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="6.0 0.05 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="blue_zone_side_right_joint" type="fixed">
    <parent link="world"/>
    <child link="blue_zone_side_right"/>
    <origin xyz="-17.0 7.0 0.001" rpy="0 0 0"/>
  </joint>

  <!-- ===================== ZONE DE BUT ROUGE (x=+20) ===================== -->
  <link name="red_zone_front">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 14.0 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="red_zone_front_joint" type="fixed">
    <parent link="world"/>
    <child link="red_zone_front"/>
    <origin xyz="14.0 0.0 0.001" rpy="0 0 0"/>
  </joint>

  <link name="red_zone_side_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="6.0 0.05 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="red_zone_side_left_joint" type="fixed">
    <parent link="world"/>
    <child link="red_zone_side_left"/>
    <origin xyz="17.0 -7.0 0.001" rpy="0 0 0"/>
  </joint>

  <link name="red_zone_side_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="6.0 0.05 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="red_zone_side_right_joint" type="fixed">
    <parent link="world"/>
    <child link="red_zone_side_right"/>
    <origin xyz="17.0 7.0 0.001" rpy="0 0 0"/>
  </joint>

  <!-- ===================== BALLE ===================== -->
  <link name="ball">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="ball_joint" type="fixed">
    <parent link="world"/>
    <child link="ball"/>
  </joint>

</robot>
