<launch>
    <let name="pkg_share" value="$(find-pkg-share handball)"/>
    <let name="xacro_file" value="$(var pkg_share)/urdf/multi_robots.xacro"/>

    <let name="robot_description_content" value="$(command 'xacro $(var xacro_file)')"/>

    <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher" output="screen">
        <param name="robot_description" value="$(var robot_description_content)"/>
    </node>

    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"/>

    <group>
        <let name="team_color" value="blue"/>

        <push-ros-namespace namespace="$(var team_color)"/>
        <node pkg="handball" exec="coach" name="coach_$(var team_color)"></node>
        
        <node pkg="handball" exec="player_node" name="player_0">
            <param name="team" value="$(var team_color)" type="str"/>
            <param name="id" value="0"/>
        </node>

        <node pkg="handball" exec="player_node" name="player_1">
            <param name="team" value="$(var team_color)" type="str"/>
            <param name="id" value="1"/>
        </node>

        <node pkg="handball" exec="player_node" name="player_2">
            <param name="team" value="$(var team_color)" type="str"/>
            <param name="id" value="2"/>
        </node>
    </group>

    <group>
        <let name="team_color" value="red"/>

        <push-ros-namespace namespace="$(var team_color)"/>
        <node pkg="handball" exec="coach" name="coach_$(var team_color)"></node>

        <node pkg="handball" exec="player_node" name="player_0">
            <param name="team" value="$(var team_color)" type="str"/>
            <param name="id" value="0"/>
        </node>

        <node pkg="handball" exec="player_node" name="player_1">
            <param name="team" value="$(var team_color)" type="str"/>
            <param name="id" value="1"/>
        </node>

        <node pkg="handball" exec="player_node" name="player_2">
            <param name="team" value="$(var team_color)" type="str"/>
            <param name="id" value="2"/>
        </node>

    </group>

    <node pkg="handball" exec="referee" name="referee" output="screen">
        <!--  Paramètres fixés directement  -->
        <param name="match_duration" value="600"/>
    </node>

    <node pkg="handball" exec="ball" name="ball" output="screen"/>
</launch>